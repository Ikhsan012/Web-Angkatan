---
const { title } = Astro.props;
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css'
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-gray-900 text-gray-100 font-sans antialiased flex flex-col min-h-screen selection:bg-blue-500 selection:text-white">
    
  <nav class="sticky top-0 z-50 bg-gray-900/80 backdrop-blur-md border-b border-gray-800 relative">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400 tracking-tighter">
          Hai!
        </a>
        
        <div class="space-x-6 hidden md:block text-sm font-semibold text-gray-300">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <a href="/kelas" class="hover:text-white transition-colors">Kelas</a>
          <a href="/galeri" class="hover:text-white transition-colors">Galeri</a>
          <a href="/kesanpesan" class="hover:text-white transition-colors">Pesan</a>
          <a href="/confess" class="hover:text-white transition-colors">Confess</a>
        </div>
        
        <button id="mobile-menu-btn" class="md:hidden text-gray-300 hover:text-white focus:outline-none">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-gray-900/95 backdrop-blur-xl border-b border-gray-800 shadow-2xl">
        <div class="flex flex-col px-6 py-4 space-y-4 text-sm font-semibold text-gray-300">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <a href="/kelas" class="hover:text-white transition-colors">Kelas</a>
          <a href="/galeri" class="hover:text-white transition-colors">Galeri</a>
          <a href="/kesanpesan" class="hover:text-white transition-colors">Pesan</a>
          <a href="/confess" class="hover:text-white transition-colors">Confess</a>
        </div>
      </div>
    </nav>

    <main class="flex-grow">
      <slot />
    </main>

<footer class="bg-gray-950 border-t border-gray-800 py-8 text-center mt-12">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-xl font-bold text-gray-300 mb-2">Angkatan 38</h2>
        <p class="text-gray-500 text-sm mb-4">Membangun kenangan, menembus masa depan.</p>
        <p class="text-gray-600 text-xs select-none">
        &copy; {new Date().getFullYear()} ATHARVA TRIASTA. Dibangun Bersama, Backend By <span id="easter-egg-trigger" class="cursor-pointer hover:text-blue-500 transition-colors font-medium">Ikhsan</span> + UI/UX By Gemini & Astro.
        </p>
      </div>
    </footer>

    <div id="ikhsan-modal" class="fixed inset-0 z-[999] bg-black/90 backdrop-blur-sm hidden items-center justify-center p-4 opacity-0 transition-opacity duration-300">
      <div class="bg-gray-900 border border-gray-700 rounded-2xl p-6 max-w-md w-full shadow-[0_0_50px_rgba(59,130,246,0.15)] transform scale-95 transition-transform duration-300 relative" id="ikhsan-modal-content">
        
        <button id="close-ikhsan-modal" class="absolute top-4 right-4 text-gray-500 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <div class="flex items-center gap-5 mb-6 mt-2">
          <div class="w-20 h-20 rounded-full overflow-hidden border-2 border-blue-500 shadow-[0_0_15px_rgba(59,130,246,0.5)] shrink-0">
            <img src="https://kwcftnoczlayucmxtlrs.supabase.co/storage/v1/object/public/logo_kelas/profil.jpg" alt="Ikhsan" class="w-full h-full object-cover" />
          </div>
          <div class="text-left">
            <h3 class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500">Ikhsan Null</h3>
            <p class="text-blue-400 text-xs font-mono tracking-widest mt-1 mb-2">Orang Biasa</p>
            <p class="text-gray-400 text-xs leading-relaxed">
            Yo, Hebat Juga Elu Bisa Nemu Easter EGG di sini, yah, ini cuma buat seru seruan doang, ya, selamat kita semua sudah lulus semoga kita jadi lebih baik ke depannya, see you again, btw masih ada beberapa easter egg, silakan mencari :)
            </p>
          </div>
        </div>

        <div class="flex gap-3 mt-4">
          <a href="https://portofolio-ikhsan.vercel.app" target="_blank" class="flex-1 text-center py-2.5 bg-blue-600 hover:bg-blue-500 rounded-lg text-white text-sm font-semibold transition-all shadow-lg hover:shadow-blue-500/25">
            Portfolio
          </a>
          <a href="https://github.com/Ikhsan012" target="_blank" class="flex-1 flex justify-center items-center gap-2 py-2.5 bg-gray-800 hover:bg-gray-700 border border-gray-600 rounded-lg text-white text-sm font-semibold transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
            GitHub
          </a>
        </div>
      </div>
    </div>

    <div class="fixed bottom-6 left-6 z-[100]">
      <button 
        id="music-toggle" 
        class="w-12 h-12 bg-gray-900 border border-gray-700 rounded-full flex items-center justify-center text-gray-400 hover:text-white hover:border-blue-500 shadow-[0_0_15px_rgba(0,0,0,0.5)] transition-all hover:scale-110 group"
        title="Play Background Music"
      >
        <svg id="icon-play" class="w-5 h-5 ml-1 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <svg id="icon-pause" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </button>
      <audio id="bg-music" loop preload="none" transition:persist="bg-music-player">
        <source src="/audio/audio.mp3" type="audio/mpeg" />
      </audio>
    </div>

  </body>
</html>

<script>

function initAudioPlayer() {
    const musicToggle = document.getElementById('music-toggle');
    const bgMusic = document.getElementById('bg-music');
    const iconPlay = document.getElementById('icon-play');
    const iconPause = document.getElementById('icon-pause');

    if (!musicToggle || !bgMusic) return;

    if (!bgMusic.paused) {
      iconPlay.classList.add('hidden');
      iconPause.classList.remove('hidden');
      musicToggle.classList.add('shadow-[0_0_20px_rgba(59,130,246,0.6)]', 'border-blue-500', 'text-blue-400');
    }

    if (musicToggle.hasAttribute('data-init')) return;
    musicToggle.setAttribute('data-init', 'true');

    bgMusic.volume = 0.3;
    let playPromise; 

    musicToggle.addEventListener('click', () => {
      if (bgMusic.paused) {
        playPromise = bgMusic.play();
        if (playPromise !== undefined) {
          playPromise.then(() => {
            iconPlay.classList.add('hidden');
            iconPause.classList.remove('hidden');
            musicToggle.classList.add('shadow-[0_0_20px_rgba(59,130,246,0.6)]', 'border-blue-500', 'text-blue-400');
          }).catch(err => console.error("Audio diblokir:", err));
        }
      } else {
        if (playPromise !== undefined) {
          playPromise.then(() => {
            bgMusic.pause();
            toggleIconsToPause();
          }).catch(err => console.log("Audio batal:", err));
        } else {
          bgMusic.pause();
          toggleIconsToPause();
        }
      }
    });

    function toggleIconsToPause() {
      iconPlay.classList.remove('hidden');
      iconPause.classList.add('hidden');
      musicToggle.classList.remove('shadow-[0_0_20px_rgba(59,130,246,0.6)]', 'border-blue-500', 'text-blue-400');
    }
  }

  document.addEventListener('astro:page-load', initAudioPlayer);

      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');

      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
      }


// easter egg
function initEasterEgg() {
    let clickCount = 0;
    let clickTimer;
    const triggerBtn = document.getElementById('easter-egg-trigger');
    const modalBox = document.getElementById('ikhsan-modal');
    const modalContent = document.getElementById('ikhsan-modal-content');
    const closeBtn = document.getElementById('close-ikhsan-modal');

    if (!triggerBtn || !modalBox) return;

    if (triggerBtn.hasAttribute('data-easter-init')) return;
    triggerBtn.setAttribute('data-easter-init', 'true');

    triggerBtn.addEventListener('click', () => {
      clickCount++;
      
      clearTimeout(clickTimer);
      clickTimer = setTimeout(() => {
        clickCount = 0;
      }, 1500);

      if (clickCount === 5) {
        modalBox.classList.remove('hidden');
        modalBox.classList.add('flex');
        
        setTimeout(() => {
          modalBox.classList.remove('opacity-0');
          modalContent.classList.remove('scale-95');
          modalContent.classList.add('scale-100');
        }, 10);
        
        clickCount = 0; 
      }
    });

    const closeModal = () => {
      modalBox.classList.add('opacity-0');
      modalContent.classList.remove('scale-100');
      modalContent.classList.add('scale-95');
      setTimeout(() => {
        modalBox.classList.add('hidden');
        modalBox.classList.remove('flex');
      }, 300); 
    }

    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modalBox.addEventListener('click', (e) => {
      if (e.target === modalBox) closeModal();
    });
    
if (!window.easterEggEscapeInit) {
      window.easterEggEscapeInit = true;
      document.addEventListener('keydown', (e) => {
        const activeModal = document.getElementById('ikhsan-modal');
        if (e.key === 'Escape' && activeModal && !activeModal.classList.contains('hidden')) {
          closeModal();
        }
      });
    }
  }

  document.addEventListener('astro:page-load', initEasterEgg);
</script>
