---
const { title } = Astro.props;
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css'

import LoadFirst from '../pages/loadfirst.astro'
---

<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-stone-900 text-stone-100 font-sans antialiased flex flex-col min-h-screen selection:bg-orange-500 selection:text-stone-900">
    <LoadFirst />
    
    <div id="page-loader" transition:persist="page-loader" class="fixed top-0 left-0 w-0 h-2 bg-orange-500 z-[10000] transition-all duration-300 ease-out opacity-0 border-b-2 border-stone-900"></div>

    <nav class="sticky top-0 z-[2000] bg-stone-900 border-b-4 border-stone-800">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        
        <a href="/" class="group relative z-50">
          <span class="text-stone-100 bg-stone-800 px-3 py-1.5 border-2 border-stone-600 shadow-[4px_4px_0_0_#57534e] font-black tracking-widest uppercase transition-all group-hover:bg-orange-500 group-hover:text-stone-900 group-hover:shadow-none group-hover:translate-x-1 group-hover:translate-y-1">
            Hai!
          </span>
        </a>
        
        <div class="hidden md:flex items-center space-x-4 text-sm font-bold text-stone-400 font-mono uppercase tracking-wider">
          <a href="/" class="px-4 py-2 border-2 border-transparent hover:border-stone-600 hover:bg-stone-800 hover:text-stone-100 transition-none">Home</a>
          <a href="/kelas" class="px-4 py-2 border-2 border-transparent hover:border-stone-600 hover:bg-stone-800 hover:text-stone-100 transition-none">Kelas</a>
          <a href="/galeri" class="px-4 py-2 border-2 border-transparent hover:border-stone-600 hover:bg-stone-800 hover:text-stone-100 transition-none">Galeri</a>
          <a href="/kesanpesan" class="px-4 py-2 border-2 border-transparent hover:border-stone-600 hover:bg-stone-800 hover:text-stone-100 transition-none">Pesan</a>
          <a href="/confess" class="px-4 py-2 border-2 border-transparent hover:border-stone-600 hover:bg-stone-800 hover:text-stone-100 transition-none">Confess</a>
        </div>
        
        <button id="mobile-menu-btn" class="relative z-[1000] md:hidden p-2 bg-stone-800 border-2 border-stone-600 text-stone-100 shadow-[4px_4px_0_0_#57534e] hover:bg-orange-500 hover:text-stone-900 hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all focus:outline-none cursor-pointer">
          <svg class="w-6 h-6 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-stone-900 border-b-4 border-stone-800 shadow-[0_20px_0_0_rgba(28,25,23,0.8)] z-[800]">
        <div class="flex flex-col px-6 py-6 space-y-4 text-sm font-bold font-mono uppercase tracking-widest text-stone-400">
          <a href="/" class="border-2 border-stone-800 p-3 hover:bg-stone-800 hover:text-stone-100 hover:border-stone-600 transition-none">Home</a>
          <a href="/kelas" class="border-2 border-stone-800 p-3 hover:bg-stone-800 hover:text-stone-100 hover:border-stone-600 transition-none">Kelas</a>
          <a href="/galeri" class="border-2 border-stone-800 p-3 hover:bg-stone-800 hover:text-stone-100 hover:border-stone-600 transition-none">Galeri</a>
          <a href="/kesanpesan" class="border-2 border-stone-800 p-3 hover:bg-stone-800 hover:text-stone-100 hover:border-stone-600 transition-none">Pesan</a>
          <a href="/confess" class="border-2 border-stone-800 p-3 hover:bg-stone-800 hover:text-stone-100 hover:border-stone-600 transition-none">Confess</a>
        </div>
      </div>
    </nav>

    <script is:inline>
      if (!window.mobileNavInit) {
        window.mobileNavInit = true;
        document.addEventListener('click', function(e) {
          const btn = e.target.closest('#mobile-menu-btn');
          const menu = document.getElementById('mobile-menu');
          
          if (!menu) return;

          if (btn) {
            menu.classList.toggle('hidden');
            return; 
          }

          if (!menu.classList.contains('hidden') && !menu.contains(e.target)) {
            menu.classList.add('hidden');
          }

          if (e.target.closest('#mobile-menu a')) {
            menu.classList.add('hidden');
          }
        });
      }
    </script>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-stone-900 border-t-4 border-stone-800 py-12 text-center mt-16 relative">
      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <h2 class="text-3xl font-black text-stone-100 mb-2 tracking-widest uppercase">Angkatan 38</h2>
        <p class="text-stone-500 font-mono text-sm mb-8 font-bold">Membangun kenangan, menembus masa depan.</p>
        
        <div class="inline-block border-2 border-stone-700 bg-stone-800 p-4 shadow-[6px_6px_0_0_#292524]">
          <p class="text-stone-400 text-xs select-none font-mono font-bold uppercase tracking-wide">
            &copy; {new Date().getFullYear()} ATHARVA TRIASTA. <br class="md:hidden" />
            Backend By <span id="easter-egg-trigger" class="cursor-pointer text-orange-500 hover:text-stone-900 hover:bg-orange-500 px-1 transition-none border border-transparent hover:border-orange-500">Ikhsan</span> <br class="md:hidden" />
            UI/UX By Gemini & Astro.
          </p>
        </div>
      </div>
    </footer>

    <div id="ikhsan-modal" class="fixed inset-0 z-[2000] bg-stone-900/90 hidden items-center justify-center p-4 opacity-0 transition-opacity duration-300 pointer-events-none">
      <div class="bg-[#f4ecd8] border-4 border-stone-900 rounded-none p-6 max-w-md w-full shadow-[16px_16px_0_0_#1c1917] transform scale-95 transition-transform duration-200 relative" id="ikhsan-modal-content">
        
        <button id="close-ikhsan-modal" class="absolute top-4 right-4 w-8 h-8 bg-stone-900 text-[#f4ecd8] border-2 border-stone-900 flex items-center justify-center hover:bg-orange-500 hover:text-stone-900 transition-none shadow-[4px_4px_0_0_#57534e] hover:shadow-none hover:translate-x-1 hover:translate-y-1">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <div class="flex items-center gap-5 mb-6 mt-4 border-b-4 border-stone-900 pb-6">
          <div class="w-24 h-24 bg-stone-200 border-4 border-stone-900 shadow-[6px_6px_0_0_#1c1917] shrink-0 p-1 transform -rotate-3 hover:rotate-0 transition-transform">
            <img src="https://kwcftnoczlayucmxtlrs.supabase.co/storage/v1/object/public/logo_kelas/profil.jpg" alt="Ikhsan" class="w-full h-full object-cover filter grayscale sepia-[20%] contrast-125" />
          </div>
          <div class="text-left">
            <h3 class="text-3xl font-black text-stone-900 uppercase tracking-tighter">Ikhsan Null</h3>
            <p class="text-stone-100 bg-stone-900 text-[10px] font-mono tracking-widest mt-2 mb-2 uppercase border-2 border-stone-900 shadow-[2px_2px_0_0_#57534e] inline-block px-2 py-1">Pengembang Web</p>
          </div>
        </div>

        <p class="text-stone-800 text-sm font-mono font-bold leading-relaxed mb-6 border-l-4 border-orange-500 pl-4">
          "Yo, Hebat Juga Elu Bisa Nemu Easter EGG di sini! Yah, ini cuma buat seru-seruan doang. Selamat kita semua sudah lulus, semoga kita jadi lebih baik ke depannya. See you again! (Btw masih ada beberapa easter egg, silakan mencari)."
        </p>

        <div class="flex gap-4 mt-4 font-mono font-bold uppercase text-sm">
          <a href="https://ikhsannull.web.id/" target="_blank" class="flex-1 text-center py-3 bg-orange-500 border-2 border-stone-900 text-stone-900 shadow-[6px_6px_0_0_#1c1917] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all">
            Portfolio
          </a>
          <a href="https://github.com/Ikhsan012" target="_blank" class="flex-1 flex justify-center items-center gap-2 py-3 bg-stone-200 border-2 border-stone-900 text-stone-900 shadow-[6px_6px_0_0_#1c1917] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
            GitHub
          </a>
        </div>
      </div>
    </div>

    <div class="fixed bottom-6 left-6 z-[1000]">
      <button 
        id="music-toggle" 
        class="w-14 h-14 bg-stone-100 border-4 border-stone-900 rounded-none flex items-center justify-center text-stone-900 shadow-[6px_6px_0_0_#1c1917] hover:bg-orange-500 hover:shadow-[2px_2px_0_0_#1c1917] hover:translate-x-1 hover:translate-y-1 transition-all group"
        title="Play Background Music"
      >
        <svg id="icon-play" class="w-6 h-6 ml-1 transition-transform group-active:scale-90" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <svg id="icon-pause" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </button>
      <audio id="bg-music" loop preload="none" transition:persist="bg-music-player">
        <source src="/audio/audio.mp3" type="audio/mpeg" />
      </audio>
    </div>

  </body>
</html>

<script>
  // 1. Audio Player Logic for Neo-Brutalism (Pressed Button Effect)
  function initAudioPlayer() {
    const musicToggle = document.getElementById('music-toggle');
    const bgMusic = document.getElementById('bg-music');
    const iconPlay = document.getElementById('icon-play');
    const iconPause = document.getElementById('icon-pause');

    if (!musicToggle || !bgMusic) return;

    // Fungsi untuk mengubah style tombol saat lagu diputar
    const setPlayingStyle = () => {
      iconPlay.classList.add('hidden');
      iconPause.classList.remove('hidden');
      // Efek tombol ditekan permanen
      musicToggle.classList.remove('bg-stone-100', 'shadow-[6px_6px_0_0_#1c1917]');
      musicToggle.classList.add('bg-orange-500', 'translate-x-1', 'translate-y-1', 'shadow-[2px_2px_0_0_#1c1917]');
    };

    // Fungsi untuk mengubah style tombol saat lagu dijeda
    const setPausedStyle = () => {
      iconPlay.classList.remove('hidden');
      iconPause.classList.add('hidden');
      // Balikin efek tombol ke awal
      musicToggle.classList.remove('bg-orange-500', 'translate-x-1', 'translate-y-1', 'shadow-[2px_2px_0_0_#1c1917]');
      musicToggle.classList.add('bg-stone-100', 'shadow-[6px_6px_0_0_#1c1917]');
    };

    if (!bgMusic.paused) {
      setPlayingStyle();
    }

    if (musicToggle.hasAttribute('data-init')) return;
    musicToggle.setAttribute('data-init', 'true');

    bgMusic.volume = 0.3;
    let playPromise; 

    musicToggle.addEventListener('click', () => {
      if (bgMusic.paused) {
        playPromise = bgMusic.play();
        if (playPromise !== undefined) {
          playPromise.then(() => {
            setPlayingStyle();
          }).catch(err => console.error("Audio diblokir:", err));
        }
      } else {
        bgMusic.pause();
        setPausedStyle();
      }
    });
  }

  // 2. Easter Egg Ikhsan Logic
  function initEasterEgg() {
    let clickCount = 0;
    let clickTimer;
    const triggerBtn = document.getElementById('easter-egg-trigger');
    const modalBox = document.getElementById('ikhsan-modal');
    const modalContent = document.getElementById('ikhsan-modal-content');
    const closeBtn = document.getElementById('close-ikhsan-modal');

    if (!triggerBtn || !modalBox) return;
    if (triggerBtn.hasAttribute('data-easter-init')) return;
    triggerBtn.setAttribute('data-easter-init', 'true');

    triggerBtn.addEventListener('click', () => {
      clickCount++;
      clearTimeout(clickTimer);
      clickTimer = setTimeout(() => { clickCount = 0; }, 1500);

      if (clickCount === 5) {
        modalBox.classList.remove('pointer-events-none', 'hidden');
        modalBox.classList.add('pointer-events-auto', 'flex');
        
        setTimeout(() => {
          modalBox.classList.remove('opacity-0');
          modalContent.classList.remove('scale-95');
          modalContent.classList.add('scale-100');
        }, 10);
        clickCount = 0; 
      }
    });

    const closeModal = () => {
      modalBox.classList.add('opacity-0');
      modalContent.classList.remove('scale-100');
      modalContent.classList.add('scale-95');
      setTimeout(() => {
        modalBox.classList.add('hidden', 'pointer-events-none');
        modalBox.classList.remove('flex', 'pointer-events-auto');
      }, 300); 
    }

    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modalBox.addEventListener('click', (e) => {
      if (e.target === modalBox) closeModal();
    });
    
    if (!window.easterEggEscapeInit) {
      window.easterEggEscapeInit = true;
      document.addEventListener('keydown', (e) => {
        const activeModal = document.getElementById('ikhsan-modal');
        if (e.key === 'Escape' && activeModal && !activeModal.classList.contains('hidden')) {
          closeModal();
        }
      });
    }
  }

  // 3. Page Transition Loader Logic
  let loaderInterval;
  document.addEventListener('astro:before-preparation', () => {
    const loader = document.getElementById('page-loader');
    if (loader) {
      loader.classList.remove('opacity-0', 'duration-500');
      loader.classList.add('duration-300');
      loader.style.width = '15%';
      clearInterval(loaderInterval);
      loaderInterval = setInterval(() => {
        let currentWidth = parseFloat(loader.style.width) || 15;
        if (currentWidth < 90) loader.style.width = (currentWidth + Math.random() * 10) + '%';
      }, 300);
    }
  });

  document.addEventListener('astro:page-load', () => {
    const loader = document.getElementById('page-loader');
    if (loader) {
      clearInterval(loaderInterval);
      loader.style.width = '100%';
      setTimeout(() => {
        loader.classList.remove('duration-300');
        loader.classList.add('duration-500', 'opacity-0');
        setTimeout(() => {
          if (loader.style.opacity === '0') loader.style.width = '0%';
        }, 500);
      }, 200);
    }
  });

  document.addEventListener('astro:page-load', initAudioPlayer);
  document.addEventListener('astro:page-load', initEasterEgg);
</script>
