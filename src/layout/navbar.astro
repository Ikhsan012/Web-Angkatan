---
const { title } = Astro.props;
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css'
---

<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-gray-950 text-gray-100 font-sans antialiased flex flex-col min-h-screen selection:bg-blue-500 selection:text-white">
    
    <div id="page-loader" transition:persist="page-loader" class="fixed top-0 left-0 w-0 h-1 bg-gradient-to-r from-blue-500 via-emerald-400 to-teal-400 z-[10000] transition-all duration-300 ease-out opacity-0 shadow-[0_0_15px_rgba(52,211,153,0.8)]"></div>

    <nav class="top-0 z-[2000] bg-gray-950/70 backdrop-blur-xl border-b border-white/5 shadow-2xl">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        
        <a href="/" class="group relative text-2xl font-black tracking-tighter z-50">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400 transition-all duration-500 group-hover:from-emerald-400 group-hover:to-blue-400">Hai!</span>
          <div class="absolute -bottom-1 left-0 w-0 h-0.5 bg-gradient-to-r from-blue-400 to-emerald-400 transition-all duration-300 group-hover:w-full"></div>
        </a>
        
        <div class="hidden md:flex items-center space-x-8 text-sm font-semibold text-gray-400">
          <a href="/" class="relative hover:text-white transition-colors py-2 group">
            Home
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-blue-500 transition-all duration-300 group-hover:w-full rounded-full"></span>
          </a>
          <a href="/kelas" class="relative hover:text-white transition-colors py-2 group">
            Kelas
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-blue-500 transition-all duration-300 group-hover:w-full rounded-full"></span>
          </a>
          <a href="/galeri" class="relative hover:text-white transition-colors py-2 group">
            Galeri
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-blue-500 transition-all duration-300 group-hover:w-full rounded-full"></span>
          </a>
          <a href="/kesanpesan" class="relative hover:text-white transition-colors py-2 group">
            Pesan
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-blue-500 transition-all duration-300 group-hover:w-full rounded-full"></span>
          </a>
          <a href="/confess" class="relative hover:text-white transition-colors py-2 group">
            Confess
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-blue-500 transition-all duration-300 group-hover:w-full rounded-full"></span>
          </a>
        </div>
        
        <button id="mobile-menu-btn" class="relative z-[1000] md:hidden p-2 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-colors focus:outline-none cursor-pointer group">
          <svg class="w-6 h-6 pointer-events-none transition-transform group-active:scale-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-gray-950/95 backdrop-blur-2xl border-b border-gray-800 shadow-[0_20px_50px_rgba(0,0,0,0.5)] z-[800]">
        <div class="flex flex-col px-6 py-6 space-y-5 text-base font-semibold text-gray-400">
          <a href="/" class="hover:text-white hover:translate-x-2 transition-all">Home</a>
          <a href="/kelas" class="hover:text-white hover:translate-x-2 transition-all">Kelas</a>
          <a href="/galeri" class="hover:text-white hover:translate-x-2 transition-all">Galeri</a>
          <a href="/kesanpesan" class="hover:text-white hover:translate-x-2 transition-all">Pesan</a>
          <a href="/confess" class="hover:text-white hover:translate-x-2 transition-all">Confess</a>
        </div>
      </div>
    </nav>

    <script is:inline>
      if (!window.mobileNavInit) {
        window.mobileNavInit = true;
        document.addEventListener('click', function(e) {
          const btn = e.target.closest('#mobile-menu-btn');
          const menu = document.getElementById('mobile-menu');
          
          if (!menu) return;

          if (btn) {
            menu.classList.toggle('hidden');
            return; 
          }

          if (!menu.classList.contains('hidden') && !menu.contains(e.target)) {
            menu.classList.add('hidden');
          }

          if (e.target.closest('#mobile-menu a')) {
            menu.classList.add('hidden');
          }
        });
      }
    </script>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-gray-950 border-t border-gray-900 py-10 text-center mt-16 relative overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-blue-500/50 to-transparent"></div>
      
      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <h2 class="text-2xl font-black text-white mb-2 tracking-tight">Angkatan 38</h2>
        <p class="text-gray-500 text-sm mb-6">Membangun kenangan, menembus masa depan.</p>
        <p class="text-gray-600 text-xs select-none font-mono">
          &copy; {new Date().getFullYear()} ATHARVA TRIASTA. <br class="md:hidden" />
          Backend By <span id="easter-egg-trigger" class="cursor-pointer hover:text-blue-400 transition-colors font-bold tracking-wide">Ikhsan</span> + UI/UX By Gemini & Astro.
        </p>
      </div>
    </footer>

    <div id="ikhsan-modal" class="fixed inset-0 z-[2000] bg-black/95 backdrop-blur-md hidden items-center justify-center p-4 opacity-0 transition-opacity duration-300 pointer-events-none">
      <div class="bg-gray-950 border border-gray-800 rounded-2xl p-6 max-w-md w-full shadow-[0_0_50px_rgba(59,130,246,0.15)] transform scale-95 transition-transform duration-300 relative" id="ikhsan-modal-content">
        
        <button id="close-ikhsan-modal" class="absolute top-4 right-4 text-gray-600 hover:text-white transition-colors hover:rotate-90 duration-300">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <div class="flex items-center gap-5 mb-6 mt-2">
          <div class="w-20 h-20 rounded-full overflow-hidden border-2 border-blue-500 shadow-[0_0_20px_rgba(59,130,246,0.3)] shrink-0">
            <img src="https://kwcftnoczlayucmxtlrs.supabase.co/storage/v1/object/public/logo_kelas/profil.jpg" alt="Ikhsan" class="w-full h-full object-cover" />
          </div>
          <div class="text-left">
            <h3 class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">Ikhsan Null</h3>
            <p class="text-blue-500 text-[10px] font-mono tracking-widest mt-1 mb-2 uppercase border border-blue-500/30 inline-block px-2 py-0.5 rounded-full bg-blue-500/10">System Admin</p>
            <p class="text-gray-400 text-xs leading-relaxed mt-2">
              Yo, Hebat Juga Elu Bisa Nemu Easter EGG di sini! Yah, ini cuma buat seru-seruan doang. Selamat kita semua sudah lulus, semoga kita jadi lebih baik ke depannya. See you again! (Btw masih ada beberapa easter egg, silakan mencari).
            </p>
          </div>
        </div>

        <div class="flex gap-3 mt-4">
          <a href="https://portofolio-ikhsan.vercel.app" target="_blank" class="flex-1 text-center py-2.5 bg-blue-600 hover:bg-blue-500 rounded-lg text-white text-sm font-semibold transition-all shadow-lg hover:shadow-blue-500/25 active:scale-95">
            Portfolio
          </a>
          <a href="https://github.com/Ikhsan012" target="_blank" class="flex-1 flex justify-center items-center gap-2 py-2.5 bg-gray-900 hover:bg-gray-800 border border-gray-700 rounded-lg text-white text-sm font-semibold transition-all active:scale-95">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
            GitHub
          </a>
        </div>
      </div>
    </div>

    <div class="fixed bottom-6 left-6 z-[1000]">
      <button 
        id="music-toggle" 
        class="w-12 h-12 bg-gray-900 border border-gray-700 rounded-full flex items-center justify-center text-gray-400 hover:text-white hover:border-blue-500 shadow-xl transition-all hover:scale-110 group"
        title="Play Background Music"
      >
        <svg id="icon-play" class="w-5 h-5 ml-1 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <svg id="icon-pause" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </button>
      <audio id="bg-music" loop preload="none" transition:persist="bg-music-player">
        <source src="/audio/audio.mp3" type="audio/mpeg" />
      </audio>
    </div>

  </body>
</html>

<script>
  // 1. Audio Player
  function initAudioPlayer() {
    const musicToggle = document.getElementById('music-toggle');
    const bgMusic = document.getElementById('bg-music');
    const iconPlay = document.getElementById('icon-play');
    const iconPause = document.getElementById('icon-pause');

    if (!musicToggle || !bgMusic) return;

    if (!bgMusic.paused) {
      iconPlay.classList.add('hidden');
      iconPause.classList.remove('hidden');
      musicToggle.classList.add('shadow-[0_0_20px_rgba(59,130,246,0.5)]', 'border-blue-500', 'text-blue-400');
    }

    if (musicToggle.hasAttribute('data-init')) return;
    musicToggle.setAttribute('data-init', 'true');

    bgMusic.volume = 0.3;
    let playPromise; 

    musicToggle.addEventListener('click', () => {
      if (bgMusic.paused) {
        playPromise = bgMusic.play();
        if (playPromise !== undefined) {
          playPromise.then(() => {
            iconPlay.classList.add('hidden');
            iconPause.classList.remove('hidden');
            musicToggle.classList.add('shadow-[0_0_20px_rgba(59,130,246,0.5)]', 'border-blue-500', 'text-blue-400');
          }).catch(err => console.error("Audio diblokir:", err));
        }
      } else {
        bgMusic.pause();
        iconPlay.classList.remove('hidden');
        iconPause.classList.add('hidden');
        musicToggle.classList.remove('shadow-[0_0_20px_rgba(59,130,246,0.5)]', 'border-blue-500', 'text-blue-400');
      }
    });
  }

  // 2. Easter Egg Ikhsan
  function initEasterEgg() {
    let clickCount = 0;
    let clickTimer;
    const triggerBtn = document.getElementById('easter-egg-trigger');
    const modalBox = document.getElementById('ikhsan-modal');
    const modalContent = document.getElementById('ikhsan-modal-content');
    const closeBtn = document.getElementById('close-ikhsan-modal');

    if (!triggerBtn || !modalBox) return;
    if (triggerBtn.hasAttribute('data-easter-init')) return;
    triggerBtn.setAttribute('data-easter-init', 'true');

    triggerBtn.addEventListener('click', () => {
      clickCount++;
      clearTimeout(clickTimer);
      clickTimer = setTimeout(() => { clickCount = 0; }, 1500);

      if (clickCount === 5) {
        modalBox.classList.remove('pointer-events-none', 'hidden');
        modalBox.classList.add('pointer-events-auto', 'flex');
        
        setTimeout(() => {
          modalBox.classList.remove('opacity-0');
          modalContent.classList.remove('scale-95');
          modalContent.classList.add('scale-100');
        }, 10);
        clickCount = 0; 
      }
    });

    const closeModal = () => {
      modalBox.classList.add('opacity-0');
      modalContent.classList.remove('scale-100');
      modalContent.classList.add('scale-95');
      setTimeout(() => {
        modalBox.classList.add('hidden', 'pointer-events-none');
        modalBox.classList.remove('flex', 'pointer-events-auto');
      }, 300); 
    }

    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modalBox.addEventListener('click', (e) => {
      if (e.target === modalBox) closeModal();
    });
    
    if (!window.easterEggEscapeInit) {
      window.easterEggEscapeInit = true;
      document.addEventListener('keydown', (e) => {
        const activeModal = document.getElementById('ikhsan-modal');
        if (e.key === 'Escape' && activeModal && !activeModal.classList.contains('hidden')) {
          closeModal();
        }
      });
    }
  }

  // 3. Page Transition Loader
  let loaderInterval;
  document.addEventListener('astro:before-preparation', () => {
    const loader = document.getElementById('page-loader');
    if (loader) {
      loader.classList.remove('opacity-0', 'duration-500');
      loader.classList.add('duration-300');
      loader.style.width = '15%';
      clearInterval(loaderInterval);
      loaderInterval = setInterval(() => {
        let currentWidth = parseFloat(loader.style.width) || 15;
        if (currentWidth < 90) loader.style.width = (currentWidth + Math.random() * 10) + '%';
      }, 300);
    }
  });

  document.addEventListener('astro:page-load', () => {
    const loader = document.getElementById('page-loader');
    if (loader) {
      clearInterval(loaderInterval);
      loader.style.width = '100%';
      setTimeout(() => {
        loader.classList.remove('duration-300');
        loader.classList.add('duration-500', 'opacity-0');
        setTimeout(() => {
          if (loader.style.opacity === '0') loader.style.width = '0%';
        }, 500);
      }, 200);
    }
  });

  // Eksekusi fungsi yang butuh reload tiap pindah halaman
  document.addEventListener('astro:page-load', initAudioPlayer);
  document.addEventListener('astro:page-load', initEasterEgg);
</script>
