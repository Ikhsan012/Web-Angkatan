---
import Layout from '../layout/navbar.astro';
import { supabase } from '../lib/supabase.js';
import '../styles/global.css';

const { data: confessions } = await supabase
  .from('confess')
  .select('*')
  .order('created_at', { ascending: false });
---

<Layout title="Confess - ATHARVA TRIASTA">
  <div class="max-w-4xl mx-auto px-6 py-12 mt-10">
    
    <div class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-4">
        Pesan <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-rose-400">Tersembunyi</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
      Ada yang belum sempat tersampaikan? Tulis di sini. 1000% Anonim, 
      </p>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 md:p-8 shadow-2xl mb-16 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-32 h-32 bg-pink-500/10 rounded-full blur-3xl -mr-10 -mt-10"></div>
      
      <form id="form-confess" class="relative z-10 flex flex-col gap-4">
        <div>
          <label for="tujuan" class="block text-sm font-medium text-gray-400 mb-1">Untuk Siapa?</label>
          <input 
            type="text" 
            id="tujuan" 
            placeholder="Inisial / Nama / Kelas..." 
            class="w-full bg-gray-950 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-pink-500 focus:ring-1 focus:ring-pink-500 transition-colors"
            required
            maxlength="50"
          />
        </div>
        
        <div>
          <label for="pesan" class="block text-sm font-medium text-gray-400 mb-1">Isi Pesan / Confess</label>
          <textarea 
            id="pesan" 
            rows="4" 
            placeholder="Jujur aja, mumpung hari terakhir..." 
            class="w-full bg-gray-950 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-pink-500 focus:ring-1 focus:ring-pink-500 transition-colors resize-none"
            required
            maxlength="500"
          ></textarea>
        </div>

        <button 
          type="submit" 
          id="btn-kirim"
          class="mt-2 bg-gradient-to-r from-pink-600 to-rose-500 hover:from-pink-500 hover:to-rose-400 text-white font-bold py-3 px-6 rounded-lg shadow-lg shadow-pink-500/30 transition-all transform hover:-translate-y-0.5"
        >
          Kirim
        </button>
      </form>
      
      <div id="alert-sukses" class="hidden mt-4 p-4 bg-green-500/10 border border-green-500/50 rounded-lg text-green-400 text-sm text-center">
        Sukses! Refresh halaman buat liat pesannya.
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="confess-grid">
      {confessions?.map((item) => (
        <div class="bg-gray-800/50 border border-gray-700 rounded-xl p-5 hover:bg-gray-800 transition-colors">
          <div class="flex items-center gap-2 mb-3">
            <span class="bg-pink-500/20 text-pink-400 text-xs font-bold px-2.5 py-1 rounded-md uppercase tracking-wider">
              Untuk: {item.to}
            </span>
          </div>
          <p class="text-gray-300 text-sm leading-relaxed whitespace-pre-wrap">{item.message}</p>
        </div>
      ))}
      
      {(!confessions || confessions.length === 0) && (
        <div class="col-span-full text-center py-10 text-gray-500 italic">
          Belum ada confess yang masuk. Jadilah yang pertama!
        </div>
      )}
    </div>

  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase.js';

  const form = document.getElementById('form-confess');
  const btnKirim = document.getElementById('btn-kirim');
  const alertSukses = document.getElementById('alert-sukses');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const tujuanInput = document.getElementById('tujuan').value.trim();
      const pesanInput = document.getElementById('pesan').value.trim();

      if (!tujuanInput || !pesanInput) return;

      const originalText = btnKirim.innerHTML;
      btnKirim.innerHTML = "Mengirim... ⏳";
      btnKirim.disabled = true;

      const { error } = await supabase
        .from('confess')
        .insert([
          { to: tujuanInput, message: pesanInput }
        ]);

      if (error) {
        console.error("Gagal kirim confess:", error);
        alert("Error");
        btnKirim.innerHTML = originalText;
        btnKirim.disabled = false;
      } else {
        form.reset();
        form.style.display = 'none';
        alertSukses.classList.remove('hidden');
        
        setTimeout(() => {
          window.location.reload();
        }, 2000);
      }
    });
  }
</script>
