---
import Layout from '../layout/navbar.astro';
import { supabase } from '../lib/supabase.js';
import '../styles/global.css'
import Typewriter from 'astro-typewriter';
import Analytics from '@vercel/analytics/astro'

const { data: totalStudents } = await supabase.from('classes').select('jumlah')
const { data: classes } = await supabase.from('classes').select('*');
const { data: galleries } = await supabase.from('galleries').select('*').limit(1600);
const randomPhotos = [...(galleries || [])]
  .sort(() => Math.random() - 0.7)
  .slice(0, 6);

const totalsiswa = totalStudents ? totalStudents.reduce((total, kelas) => total + (kelas.jumlah || 0 ), 0) : 0
---

<Layout title="Home - ATHARVA TRIASTA">
<Analytics />
  
  <section class="relative min-h-[75vh] flex items-center justify-center text-center py-20 border-b-4 border-stone-800 bg-stone-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')] pointer-events-none"></div>

    <div class="relative z-10 px-6 max-w-4xl mx-auto mt-12">
      <span class="inline-block py-1.5 px-4 bg-orange-700/20 border-2 border-orange-600 text-orange-400 text-sm font-mono font-bold tracking-[0.2em] mb-8 shadow-[4px_4px_0_0_#ea580c] transform -rotate-1">
        EST. 2026 // SMA 2 PANGKEP
      </span>
      
      <h1 class="text-5xl md:text-7xl font-black text-stone-100 tracking-tighter mb-8 drop-shadow-[4px_4px_0_#292524] uppercase">
        <Typewriter
          messages={['ATHARVA TRIASTA']}
          writeSpeed={75}
          deleteSpeed={50}
          waitWritten={1500}
          waitDeleted={1000}
        />
      </h1>
      
      <p class="text-lg md:text-xl text-stone-400 font-medium tracking-wide max-w-2xl mx-auto leading-relaxed border-t-2 border-stone-700 pt-6">
        Selamat datang di Landing Page Angkatan 38. Tempat semua cerita, tawa, dan perjuangan kita dicetak abadi.
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 -mt-10 relative z-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <div class="bg-stone-800 p-8 border-4 border-stone-400 text-center transition-transform duration-200 hover:-translate-y-2 shadow-[8px_8px_0_0_#a8a29e] hover:shadow-[12px_12px_0_0_#a8a29e]">
        <h2 class="text-7xl font-black text-stone-100 mb-2 drop-shadow-[3px_3px_0_#57534e]">{totalsiswa || 0}</h2>
        <div class="w-full h-1 bg-stone-500 my-4"></div>
        <p class="text-stone-300 font-mono tracking-widest text-sm font-bold">TOTAL SISWA</p>
      </div>
      
      <div class="bg-stone-800 p-8 border-4 border-stone-400 text-center transition-transform duration-200 hover:-translate-y-2 shadow-[8px_8px_0_0_#a8a29e] hover:shadow-[12px_12px_0_0_#a8a29e]">
        <h2 class="text-7xl font-black text-stone-100 mb-2 drop-shadow-[3px_3px_0_#57534e]">{classes?.length || 0}</h2>
        <div class="w-full h-1 bg-stone-500 my-4"></div>
        <p class="text-stone-300 font-mono tracking-widest text-sm font-bold">TOTAL KELAS</p>
      </div>

    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 my-32">
    <div class="flex items-end justify-between mb-12 border-b-4 border-stone-800 pb-4">
      <div>
        <h3 class="text-4xl font-black text-stone-100 mb-1 uppercase tracking-tight">Kepingan Memori</h3>
        <p class="text-stone-400 font-mono text-sm">Arsip visual angkatan.</p>
      </div>
      <a href="/galeri" class="text-stone-100 bg-stone-800 border-2 border-stone-600 px-4 py-2 text-sm font-bold transition-all shadow-[4px_4px_0_0_#57534e] hover:translate-x-1 hover:translate-y-1 hover:shadow-none flex items-center gap-2 uppercase">
        Buka Arsip <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
      </a>
    </div>
    
    {randomPhotos && randomPhotos.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-3 gap-8 md:gap-10 auto-rows-[280px]">
        {randomPhotos.map((foto, index) => (
          /* Polaroid Frame dengan rotasi selang-seling */
          <div class={`bg-[#f4ecd8] p-3 pb-12 border-2 border-stone-900 shadow-[8px_8px_0_0_#1c1917] relative group cursor-pointer transition-transform duration-300 hover:rotate-0 hover:z-10 hover:-translate-y-2 ${index % 2 === 0 ? 'rotate-2' : '-rotate-3'}`}>
            <img src={foto.image_url} alt={foto.title} class="w-full h-full object-cover border-2 border-stone-800 filter grayscale-[50%] sepia-[30%] contrast-125 group-hover:grayscale-0 group-hover:sepia-0 transition-all duration-500" />
            
            <div class="absolute bottom-3 left-0 w-full text-center px-4">
              <span class="text-stone-900 font-mono font-bold text-sm truncate block">{foto.title}</span>
            </div>
            
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-16 h-6 bg-yellow-500/40 backdrop-blur-sm transform rotate-2"></div>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 bg-stone-900 border-4 border-dashed border-stone-700">
        <p class="text-stone-500 font-mono text-lg font-bold uppercase tracking-widest">ERROR 404: Arsip Kosong.</p>
      </div>
    )}

    <div class="max-w-4xl mx-auto px-6 py-24 mt-20">
      
      <div class="text-center mb-10">
        <h2 class="text-4xl font-black text-stone-100 tracking-tight uppercase border-y-4 border-stone-800 py-4 inline-block">
          Sinema <span class="text-stone-500">Angkatan 38</span>
        </h2>
      </div>
      <div class="relative w-full rounded-none border-4 border-stone-400 bg-stone-900 shadow-[8px_8px_0_0_#a8a29e] md:shadow-[12px_12px_0_0_#a8a29e] aspect-video group overflow-hidden">
        
        <!-- <div class="absolute inset-0 bg-[repeating-linear-gradient(transparent,transparent_2px,rgba(0,0,0,0.3)_3px,rgba(0,0,0,0.3)_4px)] pointer-events-none z-10"></div> -->

        <iframe 
          class="absolute inset-0 w-full h-full z-0"
          src="https://www.youtube.com/embed/DysWGjQxh30?rel=0&modestbranding=1" 
          title="Video Angkatan 38" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen>
        </iframe>

        <div class="absolute top-0 left-0 w-3 h-3 md:w-4 md:h-4 border-t-4 border-l-4 border-stone-500 pointer-events-none z-20"></div>
        <div class="absolute top-0 right-0 w-3 h-3 md:w-4 md:h-4 border-t-4 border-r-4 border-stone-500 pointer-events-none z-20"></div>
        <div class="absolute bottom-0 left-0 w-3 h-3 md:w-4 md:h-4 border-b-4 border-l-4 border-stone-500 pointer-events-none z-20"></div>
        <div class="absolute bottom-0 right-0 w-3 h-3 md:w-4 md:h-4 border-b-4 border-r-4 border-stone-500 pointer-events-none z-20"></div>
      </div>
    </div>
  </section>

</Layout>
