---
import Layout from '../layout/navbar.astro';
import { supabase } from '../lib/supabase.js';
import '../styles/global.css'

const { data: initialPhotos, count: totalCount } = await supabase
  .from('galleries')
  .select('*', { count: 'exact' }) 
  .order('id', { ascending: true })
  .range(0, 23); 

const sisaAwal = (totalCount || 0) - (initialPhotos?.length || 0);
---

<Layout title="Galeri - ATHARVA TRIASTA">
  <div class="max-w-7xl mx-auto px-6 py-12 mt-10">
    
    <div class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-4">
        Galeri <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500">Kenangan</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Ada total {totalCount || 0} foto Angkatan 38 yang tersimpan.
      </p>
    </div>

    <div id="gallery-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {initialPhotos?.map((foto) => (
        <div class="gallery-item relative group rounded-xl overflow-hidden cursor-zoom-in shadow-md aspect-square bg-gray-800" data-src={foto.image_url} data-title={foto.title}>
          <img 
            src={foto.image_url} 
            alt={foto.title} 
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
            loading="lazy" 
          />
          <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4 text-left">
            <span class="text-[10px] font-bold tracking-widest text-blue-400 uppercase mb-1">{foto.category}</span>
            <span class="text-white font-semibold text-sm drop-shadow-md truncate">{foto.title}</span>
          </div>
        </div>
      ))}
    </div>

    {totalCount > 24 && (
      <div class="mt-12 flex justify-center">
        <button id="btn-load-more" class="px-8 py-3 rounded-full bg-gray-800 hover:bg-gray-700 text-white font-semibold border border-gray-700 hover:border-blue-500 transition-all flex items-center gap-2 shadow-lg disabled:opacity-50">
          Load More 
          <span id="sisa-counter" class="bg-gray-900 text-gray-300 text-xs py-1 px-2 rounded-md ml-2">{sisaAwal} sisa</span>
        </button>
      </div>
    )}
  </div>

  <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 backdrop-blur-md hidden items-center justify-center p-4">
    <button id="close-lightbox" class="absolute top-4 right-4 md:top-8 md:right-8 text-gray-400 hover:text-white transition-colors bg-gray-900/60 p-3 rounded-full hover:bg-gray-800 z-50">
      <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    <div class="relative max-w-6xl w-full flex flex-col items-center justify-center">
      <img id="lightbox-img" src="" alt="Zoomed Foto" class="max-h-[80vh] md:max-h-[90vh] max-w-full rounded-md shadow-2xl object-contain" />
      <p id="lightbox-title" class="text-gray-200 mt-4 text-base md:text-lg font-medium tracking-wide"></p>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase.js';

  let currentOffset = 24; 
  const itemsPerLoad = 24;
  let isFetching = false;

  const grid = document.getElementById('gallery-grid');
  const btnLoadMore = document.getElementById('btn-load-more');
  const sisaCounter = document.getElementById('sisa-counter');

  const initLightboxEvents = () => {
    const galleryItems = document.querySelectorAll('.gallery-item:not(.bound)');
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxTitle = document.getElementById('lightbox-title');

    galleryItems.forEach(item => {
      item.addEventListener('click', () => {
        lightboxImg.setAttribute('src', item.getAttribute('data-src') || '');
        lightboxTitle.textContent = item.getAttribute('data-title') || '';
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden'; 
      });
      item.classList.add('bound');
    });
  };

  initLightboxEvents();

  const closeBtn = document.getElementById('close-lightbox');
  const lightboxBg = document.getElementById('lightbox');

  const handleClose = () => {
    lightboxBg?.classList.add('hidden');
    lightboxBg?.classList.remove('flex');
    document.body.style.overflow = 'auto';
  };

  closeBtn?.addEventListener('click', handleClose);
  lightboxBg?.addEventListener('click', (e) => { if (e.target.id === 'lightbox') handleClose(); });

  if (btnLoadMore) {
    btnLoadMore.addEventListener('click', async () => {
      if (isFetching) return;
      isFetching = true;

      const originalText = btnLoadMore.innerHTML;
      btnLoadMore.innerText = "Sabar, lagi narik data... ⏳";
      btnLoadMore.disabled = true;

      const { data: newPhotos, error } = await supabase
        .from('galleries')
        .select('*')
        .order('id', { ascending: true })
        .range(currentOffset, currentOffset + itemsPerLoad - 1);

      if (newPhotos && newPhotos.length > 0) {
        newPhotos.forEach(foto => {
          const itemHTML = `
            <div class="gallery-item relative group rounded-xl overflow-hidden cursor-zoom-in shadow-md aspect-square bg-gray-800 animate-fade-in-up" data-src="${foto.image_url}" data-title="${foto.title}">
              <img src="${foto.image_url}" alt="${foto.title}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4 text-left">
                <span class="text-[10px] font-bold tracking-widest text-blue-400 uppercase mb-1">${foto.category}</span>
                <span class="text-white font-semibold text-sm drop-shadow-md truncate">${foto.title}</span>
              </div>
            </div>
          `;
          grid.insertAdjacentHTML('beforeend', itemHTML);
        });

        currentOffset += newPhotos.length;
        
        const totalNow = parseInt(document.querySelector('p.text-gray-400').innerText.match(/\d+/)[0]);
        const sisa = totalNow - currentOffset;
        if (sisaCounter) sisaCounter.textContent = `${sisa > 0 ? sisa : 0} sisa`;

        if (newPhotos.length < itemsPerLoad || sisa <= 0) {
          btnLoadMore.remove();
        }

        initLightboxEvents();
      }

      isFetching = false;
      btnLoadMore.innerHTML = originalText;
      btnLoadMore.disabled = false;
    });
  }
</script>
