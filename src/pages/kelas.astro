---
// src/pages/kelas.astro
import Layout from '../layout/navbar.astro';
import { supabase } from '../lib/supabase.js';
import '../styles/global.css'

const { data: classesData } = await supabase
  .from('classes')
  .select('id, name, logo_url, jumlah')
  .order('name');

const classes = classesData?.map((cls) => ({
  id: cls.id,
  name: cls.name,
  logoUrl: cls.logo_url, 
  studentCount: cls.jumlah || 0, 
})) || [];
---

<Layout title="Daftar Kelas - ATHARVA TRIASTA">
  <div class="max-w-6xl mx-auto px-6 py-12 mt-10">

    <div class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-4">
        Kelas <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500">XII</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
      Keluarga Besar Angkatan 38
      </p>
    </div>
    {classes.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 p-5">
        {classes.map((cls) => (
          <div class="bg-gray-800/40 backdrop-blur-sm border border-gray-700/50 rounded-2xl p-6 flex flex-col items-center text-center relative overflow-hidden">
            
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-emerald-500/10 rounded-full blur-3xl"></div>

            <div class="w-24 h-24 rounded-full bg-gray-900 border-4 border-gray-700/50 flex items-center justify-center mb-4 overflow-hidden shadow-lg z-10">
              {cls.logoUrl ? (
                <img src={cls.logoUrl} alt={`Logo ${cls.name}`} class="w-full h-full object-cover" />
              ) : (
                // Fallback icon kalau belum ada logo
                <svg class="w-10 h-10 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              )}
            </div>

            <div class="z-10">
              <h2 class="text-2xl font-bold text-white mb-2">{cls.name}</h2>
              <div class="items-center gap-2 bg-gray-900/80 px-4 py-1.5 rounded-full">
              <span class="text-sm font-semibold text-gray-300">
                  {cls.studentCount} Orang
                </span>
              </div>
            </div>
            
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-24 bg-gray-800/30 rounded-3xl border border-dashed border-gray-700">
        <svg class="w-16 h-16 mx-auto text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        <p class="text-gray-400 text-xl font-medium mb-2">Belum ada data kelas nih.</p>
      </div>
    )}
  </div>
</Layout>
