---
// src/pages/kelas.astro
import Layout from '../layout/navbar.astro';
import { supabase } from '../lib/supabase.js';
import '../styles/global.css'

const { data: classesData } = await supabase
  .from('classes')
  .select('id, name, logo_url, jumlah')
  .order('name');

const classes = classesData?.map((cls) => ({
  id: cls.id,
  name: cls.name,
  logoUrl: cls.logo_url, 
  studentCount: cls.jumlah || 0, 
})) || [];
---

<Layout title="Daftar Kelas - ATHARVA TRIASTA">
  <div class="max-w-6xl mx-auto px-6 py-12 mt-10">

    <div class="mb-16 text-center border-b-4 border-stone-800 pb-8">
      <span class="inline-block py-1 px-3 bg-orange-500 border-2 border-stone-900 text-stone-900 text-xs font-mono font-bold tracking-widest mb-6 shadow-[4px_4px_0_0_#1c1917] transform -rotate-2">
        SEKSI KESISWAAN
      </span>
      <h1 class="text-5xl md:text-7xl font-black text-stone-100 tracking-tighter mb-4 uppercase drop-shadow-[4px_4px_0_#292524]">
        Arsip Kelas
      </h1>
      <p class="text-stone-400 font-mono text-lg max-w-2xl mx-auto font-bold uppercase tracking-widest">
        Keluarga Besar Angkatan 38
      </p>
    </div>

    {classes.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 p-4">
        {classes.map((cls, index) => (
          /* Index Card Style dengan rotasi acak biar natural */
          <div class={`group bg-[#f4ecd8] border-4 border-stone-900 p-8 flex flex-col items-center text-center relative shadow-[8px_8px_0_0_#1c1917] transition-all duration-200 hover:-translate-y-2 hover:shadow-[12px_12px_0_0_#1c1917] hover:z-10 ${index % 2 === 0 ? 'rotate-1' : '-rotate-1'} hover:rotate-0`}>
            
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-16 h-6 bg-stone-300/80 border-2 border-stone-400 transform -rotate-3 z-20"></div>

            <div class="w-24 h-24 bg-stone-200 border-4 border-stone-900 shadow-[4px_4px_0_0_#1c1917] flex items-center justify-center mb-6 overflow-hidden z-10 transition-transform group-hover:scale-110">
              {cls.logoUrl ? (
                /* Gambar dibikin pudar/vintage, pas di-hover baru full color */
                <img src={cls.logoUrl} alt={`Logo ${cls.name}`} class="w-full h-full object-cover filter grayscale-[50%] sepia-[20%] contrast-125 group-hover:grayscale-0 group-hover:sepia-0 transition-all duration-500" />
              ) : (
                // Fallback icon Flat
                <svg class="w-10 h-10 text-stone-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              )}
            </div>

            <div class="z-10 w-full">
              <h2 class="text-3xl font-black text-stone-900 mb-4 uppercase tracking-tight border-b-2 border-stone-400 pb-2 inline-block">{cls.name}</h2>
              
              <div class="mt-2">
                <span class="inline-block bg-stone-900 text-stone-100 font-mono font-bold text-sm px-4 py-2 border-2 border-stone-900 shadow-[4px_4px_0_0_#ea580c] group-hover:bg-orange-500 group-hover:text-stone-900 transition-colors uppercase">
                  {cls.studentCount} Siswa
                </span>
              </div>
            </div>
            
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-24 bg-stone-900 border-4 border-dashed border-stone-700 shadow-[8px_8px_0_0_#1c1917]">
        <svg class="w-16 h-16 mx-auto text-stone-600 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        <p class="text-stone-500 font-mono text-xl font-bold uppercase tracking-widest">DATABASE KOSONG</p>
      </div>
    )}
  </div>
</Layout>
