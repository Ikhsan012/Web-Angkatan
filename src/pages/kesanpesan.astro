---
import Layout from '../layout/navbar.astro';
import { supabase } from '../lib/supabase.js'
import '../styles/global.css'

// Tarik data dari database lu
const { data: message } = await supabase.from('kesanpesan').select('*').order('id', { ascending: false });

---

<Layout title="Buku Tamu - ATHARVA TRIASTA">
  <div class="max-w-7xl mx-auto px-6 py-12 mt-10">
    
    <div class="mb-16 text-center border-b-4 border-stone-800 pb-8">
      <span class="inline-block py-1 px-3 bg-orange-500 border-2 border-stone-900 text-stone-900 text-xs font-mono font-bold tracking-widest mb-6 shadow-[4px_4px_0_0_#1c1917] transform rotate-1">
        BUKU TAMU DIGITAL
      </span>
      <h1 class="text-5xl md:text-7xl font-black text-stone-100 tracking-tighter mb-4 uppercase drop-shadow-[4px_4px_0_#292524]">
        Kesan & Pesan
      </h1>
      <p class="text-stone-400 font-mono text-lg max-w-2xl mx-auto font-bold uppercase tracking-widest">
        Tinggalkan jejak kenangan atau unek-unek untuk Angkatan 38.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      
      <div class="lg:col-span-1">
        <div class="bg-[#f4ecd8] p-8 border-4 border-stone-900 shadow-[12px_12px_0_0_#1c1917] sticky top-32 transform -rotate-1">
          
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-20 h-6 bg-stone-300/80 border-2 border-stone-400 transform rotate-2 z-20 pointer-events-none"></div>

          <h2 class="text-2xl font-black text-stone-900 mb-8 uppercase tracking-tighter border-b-4 border-stone-900 pb-4 inline-block">
            TULIS MEMO
          </h2>
          
          <form id="form-pesan" class="space-y-6">
            <div>
              <label class="block text-sm font-mono font-bold text-stone-900 mb-2 uppercase tracking-widest">Nama Lengkap</label>
              <input type="text" id="input-nama" placeholder="CTH: IKHSAN NULL" class="w-full bg-stone-100 border-4 border-stone-900 text-stone-900 px-4 py-3 focus:outline-none focus:bg-white focus:shadow-[4px_4px_0_0_#ea580c] transition-all placeholder-stone-400 font-mono font-bold uppercase" required />
            </div>
            
            <div>
              <label class="block text-sm font-mono font-bold text-stone-900 mb-2 uppercase tracking-widest">Kelas</label>
              <input type="text" id="input-peran" placeholder="CTH: XII.E" class="w-full bg-stone-100 border-4 border-stone-900 text-stone-900 px-4 py-3 focus:outline-none focus:bg-white focus:shadow-[4px_4px_0_0_#ea580c] transition-all placeholder-stone-400 font-mono font-bold uppercase" required />
            </div>
            
            <div>
              <label class="block text-sm font-mono font-bold text-stone-900 mb-2 uppercase tracking-widest">Pesan</label>
              <textarea id="input-pesan" rows="5" placeholder="TULIS UNTUK ANGKATAN 38..." class="w-full bg-stone-100 border-4 border-stone-900 text-stone-900 px-4 py-3 focus:outline-none focus:bg-white focus:shadow-[4px_4px_0_0_#ea580c] transition-all resize-none placeholder-stone-400 font-mono font-bold" required></textarea>
            </div>
            
            <button type="submit" class="w-full bg-orange-500 hover:bg-stone-900 text-stone-900 hover:text-orange-500 border-4 border-stone-900 font-black font-mono tracking-widest uppercase py-4 shadow-[6px_6px_0_0_#1c1917] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all">
              KIRIM PESAN
            </button>
          </form>
        </div>
      </div>

      <div class="lg:col-span-2 space-y-8" id="pesan-container">
        {message?.map((item, index) => (
          /* Kartu Memo dengan rotasi selang-seling */
          <div class={`bg-stone-200 p-8 border-4 border-stone-900 shadow-[8px_8px_0_0_#1c1917] relative group hover:z-10 hover:-translate-y-1 transition-transform duration-200 ${index % 2 === 0 ? 'rotate-1' : '-rotate-1'} hover:rotate-0`}>
            
            <div class="absolute top-4 right-6 w-4 h-4 bg-orange-500 border-2 border-stone-900 rounded-full shadow-[2px_2px_0_0_#1c1917]"></div>
            
            <svg class="absolute top-6 left-6 w-12 h-12 text-stone-300 pointer-events-none" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            
            <p class="text-stone-800 font-mono font-bold leading-relaxed mb-8 relative z-10 text-lg pt-8 pl-8 pr-4">
              "{item.pesan}"
            </p>
            
            <div class="flex items-center justify-between border-t-4 border-stone-900 pt-6 mt-auto">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-stone-900 border-2 border-stone-900 flex items-center justify-center text-stone-100 font-black text-xl shadow-[4px_4px_0_0_#ea580c]">
                  {item.nama ? item.nama.charAt(0).toUpperCase() : '?'}
                </div>
                <div>
                  <h3 class="text-stone-900 font-black uppercase tracking-tight">{item.nama}</h3>
                  <p class="text-orange-600 text-xs font-mono font-bold uppercase tracking-widest">{item.peran}</p>
                </div>
              </div>
              
              <span class="text-stone-500 text-[10px] font-mono font-bold bg-stone-300 border-2 border-stone-400 px-2 py-1 uppercase hidden md:block transform rotate-2">
                {item.time || 'ARSIP'}
              </span>
            </div>
          </div>
        ))}
        
        <div class="pt-8 flex justify-center">
          <button class="px-8 py-4 bg-stone-800 hover:bg-orange-500 border-4 border-stone-900 text-stone-100 hover:text-stone-900 font-mono font-bold uppercase tracking-widest shadow-[6px_6px_0_0_#1c1917] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all">
            BACA LEMBAR SELANJUTNYA
          </button>
        </div>

      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from "../lib/supabase";
  
  function initGuestbook() {
    const form = document.getElementById('form-pesan') as HTMLFormElement;
    const btn = form?.querySelector('button[type="submit"]');

    const badWords = [
    "anjim", "anjing", "anjir", "anjrit", "anjrot", "asu", "babi", "bacot", "bajingan", "banci",
    "bangke", "bangor", "bangsat", "bego", "bejad", "bencong", "bodat", "bugil", "bundir", "bunuh",
    "burik", "burit", "cawek", "cemen", "cipok", "cium", "colai", "coli", "colmek", "cukimai",
    "cukimay", "culun", "cumbu", "dancuk", "dewasa", "dick", "dildo", "encuk", "gay", "gei",
    "gembel", "gey", "gigolo", "gila", "goblog", "goblok", "haram", "hencet", "hentai", "idiot",
    "jablai", "jablay", "jancok", "jancuk", "jangkik", "jembut", "jilat", "jingan", "kampang", "keparat",
    "kimak", "kirik", "klentit", "klitoris", "konthol", "kontol", "koplok", "kunyuk", "kutang", "kutis",
    "kwontol", "lonte", "maho", "masturbasi", "matane", "mati", "memek", "mesum", "modar", "modyar",
    "mokad", "najis", "nazi", "ndhasmu", "nenen", "ngentot", "ngolom", "ngulum", "nigga", "nigger",
    "onani", "orgasme", "paksa", "pantat", "pantek", "pecun", "peli", "penis", "pentil", "pepek",
    "perek", "perkosa", "piatu", "porno", "pukimak", "qontol", "selangkang", "sempak", "senggama", "setan",
    "setubuh", "silet", "silit", "sinting", "sodomi", "stres", "telanjang", "telaso", "tete", "tewas",
    "titit", "togel", "toket", "tolol", "tusbol", "urin", "vagina", "xxx", "yateam", "yatim"
    ];

    function cekkatakasar(text) {
      const lowertext = text.toLowerCase()
      return badWords.find(word => {
        const regex = new RegExp(`\\b${word}\\b`, `i`)
        return regex.test(lowertext)
      })
}

    if (form && btn) {
      // Pakai .onsubmit biar nggak numpuk event listener pas pindah halaman
      form.onsubmit = async (e) => {
        e.preventDefault();
        
        const nama = (document.getElementById('input-nama') as HTMLInputElement).value;
        const peran = (document.getElementById('input-peran') as HTMLInputElement).value;
        const pesan = (document.getElementById('input-pesan') as HTMLTextAreaElement).value;

        const originaltext = btn.innerHTML;
        const formnama = cekkatakasar(nama)
        const formperan = cekkatakasar(peran)
        const formpesan = cekkatakasar(pesan)

        if (formnama || formpesan || formperan) {
          alert('Kata Kasar Terdeteksi')
          return
        }

        // Animasi tombol loading retro
        btn.innerHTML = 'MENCETAK... ⏳';
        btn.disabled = true;
        btn.classList.add('opacity-50', 'cursor-wait');

        try { 
            const { error } = await supabase.from('kesanpesan').insert([{
              nama: nama,
              peran: peran,
              pesan: pesan
            }]);

          if (error) throw error;

          form.reset();
          // Force reload biar pesan baru langsung muncul
          window.location.reload();

        } catch (err) {
          console.error('Error : ', err.message);
          alert('Gagal mencetak pesan! Coba lagi.');
        } finally {
          btn.innerHTML = originaltext;
          btn.disabled = false;
          btn.classList.remove('opacity-50', 'cursor-wait');
        }
      };
    }
  }

  // Wajib pakai ini buat support View Transitions Astro
  document.addEventListener('astro:page-load', initGuestbook);
</script>
