---
import Layout from '../layout/navbar.astro';
import { supabase } from '../lib/supabase.js'
import '../styles/global.css'

const { data: message } = await supabase.from('kesanpesan').select('*');

const dummyMessages = [
  { nama: "Ikhsan Null", peran: "ICT / Dev", pesan: "Web angkatan ini bukti nyata kalau anak IT bisa ninggalin warisan digital yang keren. Sukses terus buat Angkatan 38!", tanggal: "08 Apr 2026" },
  { nama: "Akbar", peran: "Gamer / Siswa", pesan: "Semoga kita semua bisa mencapai cita-cita masing-masing. Jangan lupa mabar Minecraft lagi kalau udah pada sibuk!", tanggal: "07 Apr 2026" },
  { nama: "Budi Santoso", peran: "Panitia Mubes", pesan: "Terima kasih atas kerja keras semuanya selama event kemarin. Kalian luar biasa, walau kadang sering debat wkwk.", tanggal: "06 Apr 2026" },
  { nama: "Siti Aminah", peran: "Bendahara", pesan: "Jangan lupa pada bayar uang kas sebelum lulus woy! Btw sukses buat kita semua yaa.", tanggal: "05 Apr 2026" },
];
---

<Layout title="Kesan & Pesan - ATHARVA TRIASTA">
  <div class="max-w-7xl mx-auto px-6 py-12 mt-10 animate-fade-in-up">
    
    <div class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-4">
        Kesan & <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-500">Pesan</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Tinggalkan jejak kenangan, unek-unek, atau harapan manis untuk Angkatan 38 di sini.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      
      <div class="lg:col-span-1">
        <div class="bg-gray-800/50 backdrop-blur-xl p-6 rounded-2xl border border-gray-700 shadow-xl sticky top-24">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            Tulis Pesanmu
          </h2>
          
          <form id="form-pesan" class="space-y-5">
            <div>
              <label class="block text-sm font-medium text-gray-400 mb-1.5">Nama</label>
              <input type="text" id="input-nama" placeholder="Cth: Ikhsan Null" class="w-full bg-gray-900/50 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all placeholder-gray-600" required />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-400 mb-1.5">Kelas</label>
              <input type="text" id="input-peran" placeholder="Cth: XII.E" class="w-full bg-gray-900/50 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all placeholder-gray-600" required />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-400 mb-1.5">Pesan</label>
              <textarea id="input-pesan" rows="4" placeholder="Terserah Apa aja" class="w-full bg-gray-900/50 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all resize-none placeholder-gray-600" required></textarea>
            </div>
            
            <button type="submit" class="w-full bg-gradient-to-r from-emerald-500 to-cyan-600 hover:from-emerald-400 hover:to-cyan-500 text-white font-bold py-3.5 rounded-xl shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_25px_rgba(16,185,129,0.5)] transform transition hover:-translate-y-0.5">
              Kirim ke DB
            </button>
          </form>
        </div>
      </div>

      <div class="lg:col-span-2 space-y-5">
        {message?.map((item) => (
          <div class="bg-gray-800/40 hover:bg-gray-800/80 transition-all duration-300 p-6 md:p-8 rounded-2xl border border-gray-700/50 shadow-md relative group overflow-hidden">
            
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-gradient-to-br from-emerald-500/10 to-cyan-500/10 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition-all duration-500"></div>
            
            <svg class="absolute top-6 right-6 w-10 h-10 text-gray-700/50 group-hover:text-emerald-500/20 transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            
            <p class="text-gray-300 leading-relaxed mb-6 relative z-10 text-lg">
              "{item.pesan}"
            </p>
            
            <div class="flex items-center justify-between border-t border-gray-700/50 pt-5 mt-auto relative z-10">
              <div class="flex items-center gap-4">
                <div class="w-11 h-11 rounded-full bg-gradient-to-br from-gray-700 to-gray-900 border border-gray-600 flex items-center justify-center text-white font-bold text-lg shadow-inner">
                  {item.nama ? item.nama.charAt(0).toUpperCase() : '?'}
                </div>
                <div>
                  <h3 class="text-white font-semibold">{item.nama}</h3>
                  <p class="text-emerald-400 text-xs font-medium uppercase tracking-wider">{item.peran}</p>
                </div>
              </div>
              <span class="text-gray-500 text-xs font-medium bg-gray-900/60 border border-gray-800 px-3 py-1.5 rounded-full hidden md:block">
                {item.time}
              </span>
            </div>
          </div>
        ))}
        
        <div class="pt-6 flex justify-center">
          <button class="px-8 py-2.5 rounded-full bg-gray-800/50 hover:bg-gray-700 border border-gray-700 text-gray-300 hover:text-white transition-all text-sm font-semibold flex items-center gap-2">
            <svg class="w-4 h-4 animate-spin hidden" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            Load Lebih Banyak
          </button>
        </div>

      </div>
      
    </div>
  </div>
</Layout>

<script>

  import { supabase } from "../lib/supabase";
  const form = document.getElementById('form-pesan')
  const btn = form?.querySelector('button[type="submit"]')

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const nama = (document.getElementById('input-nama') as HTMLFormElement).value
      const peran = (document.getElementById('input-peran') as HTMLFormElement).value
      const pesan = (document.getElementById('input-pesan') as HTMLFormElement).value

      const originaltext = btn.innerHTML
      btn.innerHTML = 'Mengirim'
      btn.disabled = true

      try { 
          const { error } = await supabase.from('kesanpesan').insert([{
            nama: nama,
            peran: peran,
            pesan: pesan
          }])

        if (error) throw error

        form.reset()
        window.location.reload()

      } catch (err) {
        console.error('Error : ', err.message)
        alert('Error')
      } finally {
        btn.innerHTML = originaltext
        btn.disabled = false
      }

    })
  }

</script>
